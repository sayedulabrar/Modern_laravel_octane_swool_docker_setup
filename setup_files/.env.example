# =============================================================================
# Application
# =============================================================================
APP_NAME=LaravelOctane
APP_ENV=local
APP_KEY=                          # filled by: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=UTC

# =============================================================================
# Logging
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                   # debug | info | warning | error | critical

# =============================================================================
# Database
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=mysql                     # service name in docker-compose.yml
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret       # MySQL root (Docker only)
DB_HOST_PORT=33060                # host port for TablePlus / DBeaver (dev only)

# =============================================================================
# Redis
# =============================================================================
REDIS_CLIENT=predis               # MUST be predis — phpredis ext is not coroutine-safe
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_MAXMEMORY=256mb
REDIS_HOST_PORT=63790             # host port for RedisInsight / redis-cli (dev only)

# =============================================================================
# Cache / Session / Queue
# =============================================================================
CACHE_STORE=redis
CACHE_PREFIX=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local             # change to s3 when using MinIO/S3

# =============================================================================
# Octane + Swoole
# =============================================================================
OCTANE_SERVER=swoole
OCTANE_HTTPS=false

# Worker count — leave blank to default to CPU cores * 2
OCTANE_WORKERS=
# Task worker count — leave blank to default to CPU cores
OCTANE_TASK_WORKERS=
# Restart workers after this many requests (prevents memory growth)
OCTANE_MAX_REQUESTS=500
# Max concurrent connections per worker
OCTANE_MAX_CONN=1024
# Max Swoole coroutines per worker
OCTANE_MAX_COROUTINE=3000

# =============================================================================
# Mail (Mailpit for local dev — no real emails sent)
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"
MAILPIT_PORT=8025                 # web UI: http://localhost:8025

# =============================================================================
# MinIO (S3-compatible local object storage)
# =============================================================================
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=app-bucket
AWS_ENDPOINT=http://minio:9000    # internal Docker network
AWS_USE_PATH_STYLE_ENDPOINT=true
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_CONSOLE_PORT=9001           # web UI: http://localhost:9001

# =============================================================================
# Nginx (ports on host machine)
# =============================================================================
HTTP_PORT=80
HTTPS_PORT=443

# =============================================================================
# Queue scaling
# =============================================================================
QUEUE_WORKERS=1                   # number of queue container replicas

# =============================================================================
# Passport (filled after: php artisan passport:install)
# =============================================================================
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=
