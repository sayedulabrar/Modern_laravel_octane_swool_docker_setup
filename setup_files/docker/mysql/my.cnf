# docker/mysql/my.cnf
# MySQL 8.0 tuning for a Dockerised Laravel application.
# Adjust innodb_buffer_pool_size based on your container's RAM allocation.

[mysqld]

# ── Character set ─────────────────────────────────────────────────────────────
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# ── InnoDB buffer pool ────────────────────────────────────────────────────────
# This is the single most impactful setting.
# Set to ~70% of available memory dedicated to MySQL.
# 1G is a safe default for a 2GB container.
innodb_buffer_pool_size      = 1G
innodb_buffer_pool_instances = 2       # 1 per 1GB of buffer pool

# ── InnoDB logging ────────────────────────────────────────────────────────────
innodb_log_file_size   = 256M          # larger = faster writes
innodb_log_buffer_size = 64M

# ── Flush settings ────────────────────────────────────────────────────────────
# O_DIRECT avoids double-buffering between InnoDB and the OS page cache
innodb_flush_method = O_DIRECT

# 1 = full ACID (flush on every commit) — safest, slightly slower
# 2 = flush once per second — risk of up to 1s of data loss on crash
innodb_flush_log_at_trx_commit = 1

# ── Connections ───────────────────────────────────────────────────────────────
max_connections     = 200
max_allowed_packet  = 256M
wait_timeout        = 28800
interactive_timeout = 28800

# ── Temp tables ───────────────────────────────────────────────────────────────
tmp_table_size     = 64M
max_heap_table_size = 64M

# ── Slow query log ────────────────────────────────────────────────────────────
slow_query_log      = 1
slow_query_log_file = /var/lib/mysql/slow.log
long_query_time     = 2
log_queries_not_using_indexes = 0

# ── Performance schema ────────────────────────────────────────────────────────
performance_schema = ON

# ── Binary log (enable for replication or point-in-time recovery) ────────────
# log_bin            = /var/lib/mysql/mysql-bin.log
# binlog_format      = ROW
# binlog_expire_logs_seconds = 604800   # 7 days

[client]
default-character-set = utf8mb4
